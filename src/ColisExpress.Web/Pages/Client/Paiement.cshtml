@page "/paiement/{commandeId:guid}"
@model ColisExpress.Web.Pages.Client.PaiementModel
@{
    ViewData["Title"] = "Paiement";
}

<section class="web-page narrow">
    <h1 class="text-center">Paiement</h1>
    <p class="subtitle text-center">Choisissez votre mode de règlement.</p>

    @if (!string.IsNullOrEmpty(Model.Error))
    {
        <div class="web-alert error">@Model.Error</div>
    }

    @if (Model.Commande is not null)
    {
        <div class="web-alert info">🚧 Paiement non réel — Stripe arrive en V2. Cliquez pour simuler la confirmation.</div>

        <div class="web-card">
            <div class="flex justify-between mb-2" style="font-size:12px;color:var(--gray-500);">
                <span>Code colis</span><span class="web-code">@Model.Commande.CodeColis</span>
            </div>
            <div class="flex justify-between mb-2" style="font-size:12px;color:var(--gray-500);">
                <span>Trajet</span><span style="font-weight:700;color:var(--gray-800);">@Model.Commande.VilleDepart → @Model.Commande.VilleArrivee</span>
            </div>
            <div class="flex justify-between mb-2" style="font-size:12px;color:var(--gray-500);">
                <span>Transporteur</span><span style="font-weight:700;color:var(--gray-800);">@Model.Commande.NomTransporteur</span>
            </div>
            <hr style="border:none;border-top:1px solid var(--gray-200);margin:12px 0;" />
            <div class="flex justify-between">
                <span style="font-size:14px;color:var(--gray-500);">Montant total à payer</span>
                <span style="font-size:24px;font-weight:800;color:var(--primary);">@Model.Commande.Total.ToString("0.00") €</span>
            </div>
        </div>

        <form method="post" asp-route-commandeId="@Model.CommandeId">
            <div class="web-card">
                <h3>Mode de paiement</h3>
                <label style="display:flex;align-items:center;gap:12px;padding:14px;border:1.5px solid var(--primary);border-radius:8px;margin-bottom:10px;cursor:pointer;background:#E8F0F7;">
                    <input type="radio" name="mode" value="Carte" checked />
                    <div style="flex:1;">
                        <div style="font-weight:700;">💳 Carte bancaire</div>
                        <div style="font-size:12px;color:var(--gray-500);">Paiement simulé pour l'instant</div>
                    </div>
                </label>

                <button type="submit" class="web-btn accent full mt-4">Confirmer le paiement @Model.Commande.Total.ToString("0.00") € →</button>
            </div>
        </form>
    }
</section>
