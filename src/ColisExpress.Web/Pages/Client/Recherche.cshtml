@page "/recherche"
@model ColisExpress.Web.Pages.Client.RechercheModel
@{
    ViewData["Title"] = "Rechercher un transporteur";
}

<section class="web-page" style="max-width:780px;">
    <h1>Trouvez un transporteur</h1>
    <p class="subtitle">Renseignez votre trajet et les détails du colis. Nous vous montrons les offres disponibles.</p>

    <form method="get" asp-page="/Client/Resultats" class="web-card">
        <h3>Trajet</h3>
        <div class="web-field-row">
            <div class="web-field">
                <label class="web-field-label">Ville de départ</label>
                <input name="villeDepart" class="web-field-input" placeholder="Paris" required />
            </div>
            <div class="web-field">
                <label class="web-field-label">Ville de destination</label>
                <input name="villeArrivee" class="web-field-input" placeholder="Alger" required />
            </div>
        </div>

        <div class="web-field-row">
            <div class="web-field">
                <label class="web-field-label">Date souhaitée</label>
                <input name="dateDepart" type="date" class="web-field-input" required />
            </div>
            <div class="web-field">
                <label class="web-field-label">Poids (kg)</label>
                <input name="poids" type="number" step="0.1" min="0.1" class="web-field-input" placeholder="12" required />
            </div>
        </div>

        <h3 class="mt-4">Détails du colis</h3>
        <div class="web-field-row">
            <div class="web-field">
                <label class="web-field-label">Type de colis</label>
                <select name="typeColis" class="web-field-select">
                    <option value="standard">Standard</option>
                    <option value="fragile">Fragile</option>
                    <option value="documents">Documents</option>
                    <option value="vetements">Vêtements</option>
                    <option value="electronique">Électronique</option>
                </select>
            </div>
            <div class="web-field">
                <label class="web-field-label">Valeur déclarée (€)</label>
                <input name="valeur" type="number" min="0" class="web-field-input" placeholder="150" />
            </div>
        </div>

        <div class="flex gap-4 items-center mt-2">
            <label style="display:flex;align-items:center;gap:6px;font-size:13px;color:var(--gray-600);">
                <input type="checkbox" name="fragile" value="true" /> Fragile
            </label>
            <label style="display:flex;align-items:center;gap:6px;font-size:13px;color:var(--gray-600);">
                <input type="checkbox" name="urgent" value="true" /> Urgent
            </label>
            <label style="display:flex;align-items:center;gap:6px;font-size:13px;color:var(--gray-600);">
                <input type="checkbox" name="assurance" value="true" /> Assurance
            </label>
        </div>

        <button type="submit" class="web-btn accent full mt-4">Rechercher des transporteurs →</button>
    </form>
</section>
