@page "/admin/utilisateurs"
@model ColisExpress.Web.Pages.Admin.UtilisateursModel
@{
    ViewData["Title"] = "Utilisateurs";
}

<h1>Utilisateurs</h1>
<p class="subtitle">@Model.TotalCount utilisateurs enregistrés</p>

@if (!string.IsNullOrEmpty(Model.Success))
{
    <div class="admin-alert success">@Model.Success</div>
}
@if (!string.IsNullOrEmpty(Model.Error))
{
    <div class="admin-alert danger">@Model.Error</div>
}

<form method="get" class="admin-card" style="padding:18px 22px;margin-bottom:24px;display:flex;align-items:center;gap:12px;">
    <input type="text" name="search" value="@Model.Search" class="admin-field-input" placeholder="Rechercher par nom, prénom ou email..." style="flex:1;" />
    <a class="admin-btn sm outline" asp-page="/Admin/Utilisateurs" asp-page-handler="ExportCsv" asp-route-search="@Model.Search" style="white-space:nowrap;">Exporter CSV</a>
</form>

<div class="admin-card">
    <table class="admin-table">
        <thead>
            <tr>
                <th>Nom complet</th>
                <th>Email</th>
                <th>Rôle</th>
                <th>Statut</th>
                <th>Inscrit le</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var u in Model.Utilisateurs)
            {
                <tr>
                    <td style="color:var(--admin-text);font-weight:600;">@u.Prenom @u.Nom</td>
                    <td>@u.Email</td>
                    <td><span class="admin-badge primary">@u.Role</span></td>
                    <td>
                        @if (u.StatutCompte == ColisExpress.Domain.Enums.StatutCompte.Actif)
                        {
                            <span class="admin-badge success">Actif</span>
                        }
                        else if (u.StatutCompte == ColisExpress.Domain.Enums.StatutCompte.Suspendu)
                        {
                            <span class="admin-badge danger">Suspendu</span>
                        }
                        else
                        {
                            <span class="admin-badge warning">En attente</span>
                        }
                    </td>
                    <td>@u.DateCreation.ToLocalTime().ToString("dd MMM yyyy")</td>
                    <td>
                        @if (u.Role != ColisExpress.Domain.Enums.RoleUtilisateur.Admin)
                        {
                            @if (u.StatutCompte == ColisExpress.Domain.Enums.StatutCompte.Actif)
                            {
                                <form method="post" asp-page-handler="Suspendre" style="display:inline;">
                                    <input type="hidden" name="utilisateurId" value="@u.Id" />
                                    <button type="submit" class="admin-btn sm danger">Suspendre</button>
                                </form>
                            }
                            else if (u.StatutCompte == ColisExpress.Domain.Enums.StatutCompte.Suspendu)
                            {
                                <form method="post" asp-page-handler="Reactiver" style="display:inline;">
                                    <input type="hidden" name="utilisateurId" value="@u.Id" />
                                    <button type="submit" class="admin-btn sm success">Réactiver</button>
                                </form>
                            }
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@if (Model.TotalPages > 1)
{
    <div style="display:flex;align-items:center;justify-content:center;gap:12px;margin-top:20px;">
        @if (Model.Page > 1)
        {
            <a class="admin-btn sm outline" asp-page="/Admin/Utilisateurs" asp-route-page="@(Model.Page - 1)" asp-route-search="@Model.Search">Précédent</a>
        }
        <span style="color:var(--admin-text);font-size:14px;">Page @Model.Page sur @Model.TotalPages</span>
        @if (Model.Page < Model.TotalPages)
        {
            <a class="admin-btn sm outline" asp-page="/Admin/Utilisateurs" asp-route-page="@(Model.Page + 1)" asp-route-search="@Model.Search">Suivant</a>
        }
    </div>
}
