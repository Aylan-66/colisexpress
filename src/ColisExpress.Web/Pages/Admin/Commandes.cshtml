@page "/admin/commandes"
@model ColisExpress.Web.Pages.Admin.CommandesModel
@{
    ViewData["Title"] = "Commandes";
}

<h1>Commandes</h1>
<p class="subtitle">@Model.TotalCount commandes au total</p>

<form method="get" class="admin-card" style="padding:18px 22px;margin-bottom:24px;display:flex;align-items:center;gap:12px;">
    <label style="font-size:13px;color:var(--admin-text-muted);white-space:nowrap;">Filtrer par statut :</label>
    <select name="Filtre" class="admin-field-input" onchange="this.form.submit();" style="max-width:260px;">
        <option value="">Tous les statuts</option>
        @foreach (var s in Enum.GetValues<ColisExpress.Domain.Enums.StatutColis>())
        {
            <option value="@s" selected="@(Model.Filtre == s.ToString() ? "selected" : null)">@s</option>
        }
    </select>
    <a class="admin-btn sm outline" asp-page="/Admin/Commandes" asp-page-handler="ExportCsv" asp-route-filtre="@Model.Filtre" style="white-space:nowrap;margin-left:auto;">Exporter CSV</a>
</form>

<div class="admin-card">
    <table class="admin-table">
        <thead>
            <tr>
                <th>Code colis</th>
                <th>Client</th>
                <th>Transporteur</th>
                <th>Trajet</th>
                <th>Statut colis</th>
                <th>Règlement</th>
                <th>Total</th>
                <th>Date</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var c in Model.Commandes)
            {
                <tr>
                    <td><span class="admin-code">@c.CodeColis</span></td>
                    <td style="color:var(--admin-text);">@c.Client</td>
                    <td>@c.Transporteur</td>
                    <td>@c.Trajet</td>
                    <td><span class="admin-badge primary">@c.StatutColis</span></td>
                    <td>
                        @switch (c.StatutReglement)
                        {
                            case ColisExpress.Domain.Enums.StatutReglement.Paye:
                                <span class="admin-badge success">Payé</span>
                                break;
                            case ColisExpress.Domain.Enums.StatutReglement.Rembourse:
                                <span class="admin-badge warning">Remboursé</span>
                                break;
                            default:
                                <span class="admin-badge neutral">En attente</span>
                                break;
                        }
                    </td>
                    <td style="font-weight:700;color:var(--admin-text);">@c.Total.ToString("0.00") €</td>
                    <td>@c.DateCreation.ToLocalTime().ToString("dd MMM HH:mm")</td>
                    <td>
                        <a href="/admin/commandes/@c.Id" class="admin-btn sm outline">Détail</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@if (Model.TotalPages > 1)
{
    <div style="display:flex;align-items:center;justify-content:center;gap:12px;margin-top:20px;">
        @if (Model.Page > 1)
        {
            <a class="admin-btn sm outline" asp-page="/Admin/Commandes" asp-route-page="@(Model.Page - 1)" asp-route-filtre="@Model.Filtre">Précédent</a>
        }
        <span style="color:var(--admin-text);font-size:14px;">Page @Model.Page sur @Model.TotalPages</span>
        @if (Model.Page < Model.TotalPages)
        {
            <a class="admin-btn sm outline" asp-page="/Admin/Commandes" asp-route-page="@(Model.Page + 1)" asp-route-filtre="@Model.Filtre">Suivant</a>
        }
    </div>
}
