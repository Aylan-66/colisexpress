@page "/admin/litiges"
@model ColisExpress.Web.Pages.Admin.LitigesModel
@{
    ViewData["Title"] = "Litiges";
}

<h1>Litiges</h1>
<p class="subtitle">Gestion des incidents et réclamations</p>

@if (!string.IsNullOrEmpty(Model.Success))
{
    <div class="admin-alert success">@Model.Success</div>
}
@if (!string.IsNullOrEmpty(Model.Error))
{
    <div class="admin-alert danger">@Model.Error</div>
}

<div class="admin-card">
    <div class="admin-card-header">
        <h3 class="admin-card-title">Colis en incident (@Model.ColisEnIncident.Count)</h3>
    </div>
    @if (!Model.ColisEnIncident.Any())
    {
        <div class="admin-card-body" style="color:var(--admin-text-muted);font-size:13px;">Aucun colis en incident pour l'instant.</div>
    }
    else
    {
        <table class="admin-table">
            <thead>
                <tr>
                    <th>Code colis</th>
                    <th>Client</th>
                    <th>Trajet</th>
                    <th>Statut</th>
                    <th>Date</th>
                    <th>Résolution</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var c in Model.ColisEnIncident)
                {
                    <tr>
                        <td><span class="admin-code">@c.CodeColis</span></td>
                        <td>@c.Client</td>
                        <td>@c.Trajet</td>
                        <td><span class="admin-badge danger">@c.StatutColis</span></td>
                        <td>@c.DateCreation.ToLocalTime().ToString("dd MMM HH:mm")</td>
                        <td>
                            <form method="post" asp-page-handler="Resoudre" style="display:flex;gap:8px;align-items:flex-start;">
                                <input type="hidden" name="commandeId" value="@c.Id" />
                                <textarea name="commentaire" class="admin-field-input" rows="2" placeholder="Commentaire de résolution..." required style="min-width:180px;max-width:300px;resize:vertical;"></textarea>
                                <button type="submit" class="admin-btn sm success" style="white-space:nowrap;">Résoudre</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>
