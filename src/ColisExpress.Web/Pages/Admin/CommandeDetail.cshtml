@page "/admin/commandes/{id:guid}"
@model ColisExpress.Web.Pages.Admin.CommandeDetailModel
@{
    ViewData["Title"] = "Détail commande";
}

@if (Model.Commande is null)
{
    <div class="admin-alert error">Commande introuvable.</div>
    <a class="admin-btn outline" asp-page="/Admin/Commandes">← Retour</a>
}
else
{
    var c = Model.Commande;
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:24px;">
        <div>
            <h1 style="margin-bottom:4px;">Commande <span class="admin-code">@c.CodeColis</span></h1>
            <p class="subtitle" style="margin:0;">Créée le @c.DateCreation.ToLocalTime().ToString("dd MMM yyyy à HH:mm")</p>
        </div>
        <a class="admin-btn outline" asp-page="/Admin/Commandes">← Liste</a>
    </div>

    @if (!string.IsNullOrEmpty(Model.Success)) { <div class="admin-alert success">@Model.Success</div> }
    @if (!string.IsNullOrEmpty(Model.Error)) { <div class="admin-alert error">@Model.Error</div> }

    <div class="admin-grid-2">
        <div>
            <div class="admin-card">
                <div class="admin-card-header">
                    <h3 class="admin-card-title">Statut</h3>
                    <div style="display:flex;gap:8px;">
                        <span class="admin-badge primary">@c.StatutColis</span>
                        @switch (c.StatutReglement)
                        {
                            case ColisExpress.Domain.Enums.StatutReglement.Paye:
                                <span class="admin-badge success">Payé</span>break;
                            case ColisExpress.Domain.Enums.StatutReglement.Rembourse:
                                <span class="admin-badge warning">Remboursé</span>break;
                            default:
                                <span class="admin-badge neutral">En attente</span>break;
                        }
                    </div>
                </div>
                <div class="admin-card-body" style="font-size:13px;">
                    <div style="margin-bottom:10px;"><span style="color:var(--admin-text-muted);">Code retrait :</span> <strong style="letter-spacing:4px;">@c.CodeRetrait</strong></div>
                    <div style="margin-bottom:10px;"><span style="color:var(--admin-text-muted);">Trajet :</span> <strong>@c.Trajet</strong></div>
                    <div style="margin-bottom:10px;"><span style="color:var(--admin-text-muted);">Départ :</span> <strong>@c.DateDepart.ToLocalTime().ToString("dd MMM yyyy")</strong></div>
                </div>
            </div>

            <div class="admin-card">
                <div class="admin-card-header"><h3 class="admin-card-title">Client</h3></div>
                <div class="admin-card-body" style="font-size:13px;">
                    <div style="margin-bottom:8px;"><strong>@c.Client</strong></div>
                    <div style="color:var(--admin-text-muted);">@c.EmailClient</div>
                </div>
            </div>

            <div class="admin-card">
                <div class="admin-card-header"><h3 class="admin-card-title">Transporteur</h3></div>
                <div class="admin-card-body" style="font-size:13px;"><strong>@c.Transporteur</strong></div>
            </div>

            <div class="admin-card">
                <div class="admin-card-header"><h3 class="admin-card-title">Destinataire</h3></div>
                <div class="admin-card-body" style="font-size:13px;">
                    <div style="margin-bottom:6px;"><span style="color:var(--admin-text-muted);">Nom :</span> <strong>@c.NomDestinataire</strong></div>
                    <div style="margin-bottom:6px;"><span style="color:var(--admin-text-muted);">Tél :</span> <strong>@c.TelephoneDestinataire</strong></div>
                    <div><span style="color:var(--admin-text-muted);">Ville :</span> <strong>@c.VilleDestinataire</strong></div>
                </div>
            </div>

            <div class="admin-card">
                <div class="admin-card-header"><h3 class="admin-card-title">Colis</h3></div>
                <div class="admin-card-body" style="font-size:13px;">
                    <div style="margin-bottom:6px;"><span style="color:var(--admin-text-muted);">Description :</span> <strong>@c.DescriptionContenu</strong></div>
                    <div style="margin-bottom:6px;"><span style="color:var(--admin-text-muted);">Poids :</span> <strong>@c.PoidsDeclare kg</strong></div>
                    @if (!string.IsNullOrEmpty(c.Dimensions)) { <div style="margin-bottom:6px;"><span style="color:var(--admin-text-muted);">Dimensions :</span> <strong>@c.Dimensions</strong></div> }
                    <div style="margin-bottom:6px;"><span style="color:var(--admin-text-muted);">Valeur déclarée :</span> <strong>@c.ValeurDeclaree.ToString("0.00") €</strong></div>
                    @if (!string.IsNullOrEmpty(c.InstructionsParticulieres))
                    {
                        <div style="margin-top:8px;padding:10px;background:var(--admin-bg);border-radius:6px;"><span style="color:var(--admin-text-muted);">Instructions :</span> @c.InstructionsParticulieres</div>
                    }
                </div>
            </div>
        </div>

        <div>
            <div class="admin-card">
                <div class="admin-card-header"><h3 class="admin-card-title">Financier</h3></div>
                <div class="admin-card-body" style="font-size:13px;">
                    <div style="display:flex;justify-content:space-between;margin-bottom:8px;"><span style="color:var(--admin-text-muted);">Transport</span><strong>@c.PrixTransport.ToString("0.00") €</strong></div>
                    <div style="display:flex;justify-content:space-between;margin-bottom:8px;"><span style="color:var(--admin-text-muted);">Frais service</span><strong>@c.FraisService.ToString("0.00") €</strong></div>
                    @if (c.SupplementsTotal > 0)
                    {
                        <div style="display:flex;justify-content:space-between;margin-bottom:8px;"><span style="color:var(--admin-text-muted);">Suppléments</span><strong>@c.SupplementsTotal.ToString("0.00") €</strong></div>
                    }
                    <hr style="border:none;border-top:1px solid var(--admin-border);margin:10px 0;" />
                    <div style="display:flex;justify-content:space-between;font-size:18px;font-weight:800;"><span>Total</span><span style="color:var(--admin-primary);">@c.Total.ToString("0.00") €</span></div>
                </div>
            </div>

            <div class="admin-card">
                <div class="admin-card-header"><h3 class="admin-card-title">Timeline</h3></div>
                <div class="admin-card-body">
                    <a class="admin-btn outline" asp-page="/Admin/Colis" asp-route-codeColis="@c.CodeColis" style="width:100%;justify-content:center;">Voir la timeline complète →</a>
                </div>
            </div>

            @if (c.EstAnnulable)
            {
                <div class="admin-card">
                    <div class="admin-card-header"><h3 class="admin-card-title" style="color:var(--admin-danger);">Annulation</h3></div>
                    <div class="admin-card-body">
                        <p style="font-size:12px;color:var(--admin-text-muted);margin-bottom:12px;">Cette commande peut être annulée depuis le dashboard admin.</p>
                        <a class="admin-btn danger" asp-page="/Admin/Commandes" style="width:100%;justify-content:center;">Gérer via la liste</a>
                    </div>
                </div>
            }
        </div>
    </div>
}
