@page "/"
@model IndexModel
@{
    ViewData["Title"] = "Accueil";
}

<section class="web-page">
    <div style="text-align:center;padding:40px 16px 24px;">
        <div style="display:inline-block;background:var(--accent);color:white;font-weight:800;font-size:12px;padding:6px 14px;border-radius:20px;letter-spacing:1px;text-transform:uppercase;margin-bottom:16px;">
            France → Maghreb
        </div>
        <h1 style="font-size:44px;line-height:1.15;margin-bottom:16px;">
            Envoyez vos colis <span class="text-accent">simplement</span><br>vers le Maghreb
        </h1>
        <p style="font-size:16px;color:var(--gray-500);max-width:560px;margin:0 auto 32px;">
            Confiez vos colis à des transporteurs vérifiés. Suivi digital de bout en bout, de la France vers l'Algérie, le Maroc et la Tunisie.
        </p>
        <div class="flex gap-2 items-center" style="justify-content:center;">
            <a class="web-btn accent" asp-page="/Client/Recherche">Rechercher un transporteur →</a>
            <a class="web-btn outline" asp-page="/Client/Suivi">Suivre un colis</a>
        </div>
    </div>

    <div class="kpi-grid" style="margin-top:48px;">
        <div class="kpi-card text-center">
            <div class="kpi-label">Étape 1</div>
            <div style="font-size:32px;margin:8px 0;">🔎</div>
            <div style="font-weight:700;color:var(--gray-800);">Cherchez</div>
            <div class="kpi-hint">Ville de départ et destination</div>
        </div>
        <div class="kpi-card text-center">
            <div class="kpi-label">Étape 2</div>
            <div style="font-size:32px;margin:8px 0;">📦</div>
            <div style="font-weight:700;color:var(--gray-800);">Réservez</div>
            <div class="kpi-hint">Transporteur vérifié, prix fixe</div>
        </div>
        <div class="kpi-card text-center">
            <div class="kpi-label">Étape 3</div>
            <div style="font-size:32px;margin:8px 0;">📍</div>
            <div style="font-weight:700;color:var(--gray-800);">Suivez</div>
            <div class="kpi-hint">Timeline en temps réel</div>
        </div>
        <div class="kpi-card text-center">
            <div class="kpi-label">Étape 4</div>
            <div style="font-size:32px;margin:8px 0;">✅</div>
            <div style="font-weight:700;color:var(--gray-800);">Livré</div>
            <div class="kpi-hint">Retrait par code sécurisé</div>
        </div>
    </div>
</section>
