@page "/inscription"
@model ColisExpress.Web.Pages.Client.InscriptionModel
@{
    ViewData["Title"] = "Inscription";
}

<section class="web-page narrow">
    <div class="text-center mb-4">
        <h1 class="web-card-title">Créer un compte</h1>
        <p class="web-card-subtitle">Envoyez vos colis vers le Maghreb en toute simplicité</p>
    </div>

    <form method="post" class="web-card">
        @if (!string.IsNullOrEmpty(Model.Error))
        {
            <div class="web-alert error">@Model.Error</div>
        }

        <div class="web-field-row">
            <div class="web-field">
                <label class="web-field-label" for="Input_Prenom">Prénom</label>
                <input class="web-field-input" id="Input_Prenom" asp-for="Input.Prenom" autocomplete="given-name" required />
            </div>
            <div class="web-field">
                <label class="web-field-label" for="Input_Nom">Nom</label>
                <input class="web-field-input" id="Input_Nom" asp-for="Input.Nom" autocomplete="family-name" required />
            </div>
        </div>

        <div class="web-field">
            <label class="web-field-label" for="Input_Email">Email</label>
            <input class="web-field-input" id="Input_Email" type="email" asp-for="Input.Email" autocomplete="email" required />
        </div>

        <div class="web-field">
            <label class="web-field-label" for="Input_Telephone">Téléphone</label>
            <input class="web-field-input" id="Input_Telephone" type="tel" asp-for="Input.Telephone" autocomplete="tel" placeholder="+33 6 12 34 56 78" required />
        </div>

        <div class="web-field">
            <label class="web-field-label" for="Input_MotDePasse">Mot de passe</label>
            <input class="web-field-input" id="Input_MotDePasse" type="password" asp-for="Input.MotDePasse" autocomplete="new-password" minlength="8" required />
        </div>

        <div class="web-field">
            <label class="web-field-label" for="Input_Confirmation">Confirmer le mot de passe</label>
            <input class="web-field-input" id="Input_Confirmation" type="password" asp-for="Input.ConfirmationMotDePasse" autocomplete="new-password" minlength="8" required />
        </div>

        <button type="submit" class="web-btn full mt-2">Créer mon compte</button>

        <p class="text-center text-muted mt-4" style="font-size:13px;">
            Déjà inscrit ?
            <a asp-page="/Client/Connexion" class="text-primary" style="font-weight:700;">Se connecter</a>
        </p>
    </form>
</section>
