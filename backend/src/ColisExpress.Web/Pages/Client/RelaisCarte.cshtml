@page "/relais-carte"
@model ColisExpress.Web.Pages.Client.RelaisCarteModel
@{
    ViewData["Title"] = "Carte des points relais";
}

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="" />
<style>
    #relais-map { height: 65vh; min-height: 500px; border-radius: 12px; }
    .relais-list { display: grid; gap: 10px; margin-top: 24px; }
    .relais-card { background:#fff; border:1px solid #e5e7eb; border-radius:10px; padding:14px 18px; display:flex; gap:14px; align-items:flex-start; cursor:pointer; transition:.15s; }
    .relais-card:hover { border-color:#1B4965; box-shadow:0 2px 8px rgba(27,73,101,.08); }
    .relais-card.active { border-color:#1B4965; background:#F0F6FA; }
    .relais-icon { width:36px; height:36px; flex-shrink:0; background:#1B4965; color:#fff; border-radius:8px; display:flex; align-items:center; justify-content:center; font-weight:700; }
    .leaflet-popup-content { font-family: inherit; min-width:180px; }
    .leaflet-popup-content strong { color:#1B4965; }
</style>

<section class="web-page" style="max-width:1100px;">
    <h1>Carte des points relais</h1>
    <p class="subtitle">@Model.Relais.Count points relais disponibles. Cliquez sur un marqueur ou une carte pour zoomer.</p>

    <div id="relais-map"></div>

    <div class="relais-list">
        @foreach (var r in Model.Relais)
        {
            <div class="relais-card" data-lat="@r.Lat.ToString(System.Globalization.CultureInfo.InvariantCulture)" data-lng="@r.Lng.ToString(System.Globalization.CultureInfo.InvariantCulture)" data-id="@r.Id">
                <div class="relais-icon">📍</div>
                <div style="flex:1;">
                    <div style="font-weight:700;color:#1B4965;">@r.Nom</div>
                    <div style="font-size:13px;color:#6b7280;margin-top:2px;">@r.Adresse, @r.Ville (@r.Pays)</div>
                    @if (!string.IsNullOrEmpty(r.Horaires))
                    {
                        <div style="font-size:12px;color:#6b7280;margin-top:4px;">🕐 @r.Horaires</div>
                    }
                    <div style="font-size:12px;color:#6b7280;margin-top:2px;">📞 @r.Telephone</div>
                </div>
            </div>
        }
    </div>
</section>

@section Scripts {
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>
    <script>
        const relais = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Relais.Select(r => new {
            id = r.Id, nom = r.Nom, adresse = r.Adresse, ville = r.Ville, pays = r.Pays,
            telephone = r.Telephone, lat = r.Lat, lng = r.Lng, horaires = r.Horaires
        })));

        const map = L.map('relais-map').setView([44, 2], 4);
        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
            maxZoom: 18,
            attribution: '© OpenStreetMap'
        }).addTo(map);

        const markers = {};
        const bounds = [];
        relais.forEach(r => {
            const m = L.marker([r.lat, r.lng]).addTo(map);
            const popup = `<strong>${r.nom}</strong><br>${r.adresse}<br>${r.ville} (${r.pays})<br><span style="color:#6b7280;font-size:12px;">📞 ${r.telephone}</span>${r.horaires ? '<br><span style="color:#6b7280;font-size:12px;">🕐 ' + r.horaires + '</span>' : ''}`;
            m.bindPopup(popup);
            markers[r.id] = m;
            bounds.push([r.lat, r.lng]);
        });
        if (bounds.length) map.fitBounds(bounds, { padding: [40, 40] });

        document.querySelectorAll('.relais-card').forEach(card => {
            card.addEventListener('click', () => {
                document.querySelectorAll('.relais-card.active').forEach(c => c.classList.remove('active'));
                card.classList.add('active');
                const lat = parseFloat(card.dataset.lat);
                const lng = parseFloat(card.dataset.lng);
                const id = card.dataset.id;
                map.setView([lat, lng], 13, { animate: true });
                if (markers[id]) markers[id].openPopup();
            });
        });

        if ('geolocation' in navigator) {
            navigator.geolocation.getCurrentPosition(pos => {
                const userLatLng = [pos.coords.latitude, pos.coords.longitude];
                L.marker(userLatLng, { title: 'Votre position' })
                    .addTo(map)
                    .bindPopup('<strong>Vous êtes ici</strong>');
                document.querySelectorAll('.relais-card').forEach(card => {
                    const lat = parseFloat(card.dataset.lat);
                    const lng = parseFloat(card.dataset.lng);
                    const d = haversine(pos.coords.latitude, pos.coords.longitude, lat, lng);
                    const info = document.createElement('div');
                    info.style.cssText = 'font-size:12px;color:#1B4965;margin-top:4px;font-weight:600;';
                    info.textContent = `≈ ${d.toFixed(1)} km`;
                    card.querySelector('div[style*="flex:1"]').appendChild(info);
                });
            }, () => {}, { timeout: 5000 });
        }

        function haversine(lat1, lng1, lat2, lng2) {
            const R = 6371;
            const toRad = x => x * Math.PI / 180;
            const dLat = toRad(lat2 - lat1), dLng = toRad(lng2 - lng1);
            const a = Math.sin(dLat/2)**2 + Math.cos(toRad(lat1)) * Math.cos(toRad(lat2)) * Math.sin(dLng/2)**2;
            return 2 * R * Math.asin(Math.sqrt(a));
        }
    </script>
}
