@page "/inscription-transporteur"
@model ColisExpress.Web.Pages.Client.InscriptionTransporteurModel
@{
    ViewData["Title"] = "Devenir transporteur";
}

<section class="web-page narrow">
    <div class="text-center mb-4">
        <h1 class="web-card-title">Devenir transporteur</h1>
        <p class="web-card-subtitle">Créez votre compte transporteur et commencez à transporter des colis vers le Maghreb</p>
    </div>

    <form method="post" class="web-card">
        @if (!string.IsNullOrEmpty(Model.Error))
        {
            <div class="web-alert error">@Model.Error</div>
        }

        <h3>Informations personnelles</h3>
        <div class="web-field-row">
            <div class="web-field">
                <label class="web-field-label" for="Input_Prenom">Prénom</label>
                <input class="web-field-input" id="Input_Prenom" asp-for="Input.Prenom" autocomplete="given-name" required />
            </div>
            <div class="web-field">
                <label class="web-field-label" for="Input_Nom">Nom</label>
                <input class="web-field-input" id="Input_Nom" asp-for="Input.Nom" autocomplete="family-name" required />
            </div>
        </div>
        <div class="web-field">
            <label class="web-field-label">Email</label>
            <input class="web-field-input" type="email" asp-for="Input.Email" autocomplete="email" required />
        </div>
        <div class="web-field">
            <label class="web-field-label">Téléphone</label>
            <input class="web-field-input" type="tel" asp-for="Input.Telephone" autocomplete="tel" placeholder="+33 6 12 34 56 78" required />
        </div>
        <div class="web-field">
            <label class="web-field-label">Mot de passe</label>
            <input class="web-field-input" type="password" asp-for="Input.MotDePasse" autocomplete="new-password" minlength="8" required />
        </div>
        <div class="web-field">
            <label class="web-field-label">Confirmer le mot de passe</label>
            <input class="web-field-input" type="password" asp-for="Input.ConfirmationMotDePasse" autocomplete="new-password" minlength="8" required />
        </div>

        <h3 class="mt-4">Véhicule & corridors</h3>
        <div class="web-field">
            <label class="web-field-label">Type de véhicule</label>
            <select class="web-field-select" asp-for="Input.TypeVehicule" required>
                <option value="">Sélectionnez...</option>
                <option value="Utilitaire 6m³">Utilitaire 6m³</option>
                <option value="Fourgon 8m³">Fourgon 8m³</option>
                <option value="Fourgon 12m³">Fourgon 12m³</option>
                <option value="Camion 20m³">Camion 20m³</option>
                <option value="Camion 30m³+">Camion 30m³+</option>
                <option value="Véhicule particulier">Véhicule particulier</option>
            </select>
        </div>
        <div class="web-field">
            <label class="web-field-label">Corridors actifs</label>
            <div class="flex gap-4 items-center mt-2" style="flex-wrap:wrap;">
                <label style="display:flex;align-items:center;gap:6px;font-size:13px;color:var(--gray-600);">
                    <input type="checkbox" name="corridors" value="FR-DZ" /> France → Algérie
                </label>
                <label style="display:flex;align-items:center;gap:6px;font-size:13px;color:var(--gray-600);">
                    <input type="checkbox" name="corridors" value="FR-MA" /> France → Maroc
                </label>
                <label style="display:flex;align-items:center;gap:6px;font-size:13px;color:var(--gray-600);">
                    <input type="checkbox" name="corridors" value="FR-TN" /> France → Tunisie
                </label>
            </div>
        </div>

        <button type="submit" class="web-btn full mt-4">Créer mon compte transporteur</button>

        <p class="text-center text-muted mt-4" style="font-size:13px;">
            Déjà inscrit ?
            <a asp-page="/Client/Connexion" class="text-primary" style="font-weight:700;">Se connecter</a>
            — ou
            <a asp-page="/Client/Inscription" class="text-primary" style="font-weight:700;">S'inscrire comme client</a>
        </p>
    </form>
</section>
