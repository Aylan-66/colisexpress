@page "/admin/transporteurs"
@model ColisExpress.Web.Pages.Admin.TransporteursModel
@{
    ViewData["Title"] = "Transporteurs";
}

<h1>Transporteurs</h1>
<p class="subtitle">Validation KYC et gestion des transporteurs</p>

@if (!string.IsNullOrEmpty(Model.Success)) { <div class="admin-alert success">@Model.Success</div> }
@if (!string.IsNullOrEmpty(Model.Error)) { <div class="admin-alert error">@Model.Error</div> }

<div class="admin-card">
    <table class="admin-table">
        <thead>
            <tr>
                <th>Transporteur</th>
                <th>Email / Téléphone</th>
                <th>Véhicule</th>
                <th>Note</th>
                <th>KYC</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var t in Model.Transporteurs)
            {
                <tr>
                    <td style="color:var(--admin-text);font-weight:600;">@t.Nom</td>
                    <td>
                        @t.Email<br>
                        <span style="font-size:11px;color:var(--admin-text-muted);">@t.Telephone</span>
                    </td>
                    <td>@t.TypeVehicule</td>
                    <td>⭐ @t.NoteMoyenne.ToString("0.0") (@t.NombreAvis)</td>
                    <td>
                        @switch (t.StatutKyc)
                        {
                            case ColisExpress.Domain.Enums.StatutKyc.Valide:
                                <span class="admin-badge success">Validé</span>
                                break;
                            case ColisExpress.Domain.Enums.StatutKyc.EnAttente:
                                <span class="admin-badge warning">En attente</span>
                                break;
                            case ColisExpress.Domain.Enums.StatutKyc.Rejete:
                                <span class="admin-badge danger">Rejeté</span>
                                break;
                            default:
                                <span class="admin-badge neutral">Non soumis</span>
                                break;
                        }
                    </td>
                    <td style="display:flex;gap:6px;align-items:center;">
                        <a class="admin-btn sm outline" asp-page="/Admin/Transporteurs" asp-route-voirKyc="@t.Id">📄 Docs</a>
                        @if (t.StatutKyc == ColisExpress.Domain.Enums.StatutKyc.EnAttente)
                        {
                            <form method="post" style="display:inline-flex;gap:6px;margin:0;">
                                <input type="hidden" name="transporteurId" value="@t.Id" />
                                <button type="submit" asp-page-handler="Approve" class="admin-btn sm success">✓</button>
                                <button type="submit" asp-page-handler="Reject" class="admin-btn sm danger">✗</button>
                            </form>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@if (Model.VoirKyc.HasValue)
{
    <div class="admin-card">
        <div class="admin-card-header">
            <h3 class="admin-card-title">Documents KYC</h3>
            <a class="admin-btn sm outline" asp-page="/Admin/Transporteurs">Fermer</a>
        </div>
        @if (!Model.Documents.Any())
        {
            <div class="admin-card-body" style="color:var(--admin-text-muted);">Aucun document soumis par ce transporteur.</div>
        }
        else
        {
            <table class="admin-table">
                <thead>
                    <tr>
                        <th>Type</th>
                        <th>Fichier</th>
                        <th>Statut</th>
                        <th>Soumis le</th>
                        <th>Voir</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var doc in Model.Documents)
                    {
                        <tr>
                            <td style="color:var(--admin-text);font-weight:600;">@doc.TypeDocument</td>
                            <td>@doc.NomFichier</td>
                            <td>
                                @switch (doc.Statut)
                                {
                                    case ColisExpress.Domain.Enums.StatutKyc.Valide:
                                        <span class="admin-badge success">Validé</span>
                                        break;
                                    case ColisExpress.Domain.Enums.StatutKyc.Rejete:
                                        <span class="admin-badge danger">Rejeté</span>
                                        break;
                                    default:
                                        <span class="admin-badge warning">En attente</span>
                                        break;
                                }
                            </td>
                            <td>@doc.DateSoumission.ToLocalTime().ToString("dd MMM yyyy HH:mm")</td>
                            <td>
                                <div style="display:flex;gap:6px;align-items:center;">
                                    <a href="/api/kyc/document/@doc.Id" target="_blank" class="admin-btn sm outline">Ouvrir ↗</a>
                                    @if (doc.Statut == ColisExpress.Domain.Enums.StatutKyc.EnAttente)
                                    {
                                        <form method="post" style="margin:0;">
                                            <input type="hidden" name="documentId" value="@doc.Id" />
                                            <input type="hidden" name="voirKyc" value="@Model.VoirKyc" />
                                            <button type="submit" asp-page-handler="ApproveDoc" class="admin-btn sm success">✓</button>
                                        </form>
                                        <form method="post" style="margin:0;">
                                            <input type="hidden" name="documentId" value="@doc.Id" />
                                            <input type="hidden" name="voirKyc" value="@Model.VoirKyc" />
                                            <button type="submit" asp-page-handler="RejectDoc" class="admin-btn sm danger">✗</button>
                                        </form>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
}
