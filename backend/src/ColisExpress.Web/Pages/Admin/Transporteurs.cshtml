@page "/admin/transporteurs"
@model ColisExpress.Web.Pages.Admin.TransporteursModel
@{
    ViewData["Title"] = "Transporteurs";
}

<h1>Transporteurs</h1>
<p class="subtitle">Validation KYC et gestion des transporteurs</p>

@if (!string.IsNullOrEmpty(Model.Success)) { <div class="admin-alert success">@Model.Success</div> }
@if (!string.IsNullOrEmpty(Model.Error)) { <div class="admin-alert error">@Model.Error</div> }

<div class="admin-card">
    <table class="admin-table">
        <thead>
            <tr>
                <th>Transporteur</th>
                <th>Email / Téléphone</th>
                <th>Véhicule</th>
                <th>Note</th>
                <th>KYC</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var t in Model.Transporteurs)
            {
                <tr>
                    <td style="color:var(--admin-text);font-weight:600;">@t.Nom</td>
                    <td>
                        @t.Email<br>
                        <span style="font-size:11px;color:var(--admin-text-muted);">@t.Telephone</span>
                    </td>
                    <td>@t.TypeVehicule</td>
                    <td>⭐ @t.NoteMoyenne.ToString("0.0") (@t.NombreAvis)</td>
                    <td>
                        @switch (t.StatutKyc)
                        {
                            case ColisExpress.Domain.Enums.StatutKyc.Valide:
                                <span class="admin-badge success">Validé</span>
                                break;
                            case ColisExpress.Domain.Enums.StatutKyc.EnAttente:
                                <span class="admin-badge warning">En attente</span>
                                break;
                            case ColisExpress.Domain.Enums.StatutKyc.Rejete:
                                <span class="admin-badge danger">Rejeté</span>
                                break;
                            default:
                                <span class="admin-badge neutral">Non soumis</span>
                                break;
                        }
                    </td>
                    <td>
                        <a class="admin-btn sm outline" asp-page="/Admin/Transporteurs" asp-route-voirKyc="@t.Id">📄 Voir les documents</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@if (Model.VoirKyc.HasValue)
{
    <div class="admin-card">
        <div class="admin-card-header">
            <h3 class="admin-card-title">Documents KYC</h3>
            <a class="admin-btn sm outline" asp-page="/Admin/Transporteurs">✕ Fermer</a>
        </div>
        @if (!Model.Documents.Any())
        {
            <div class="admin-card-body" style="color:var(--admin-text-muted);">Aucun document soumis par ce transporteur.</div>
        }
        else
        {
            <div class="admin-card-body" style="display:flex;flex-direction:column;gap:16px;">
                @foreach (var doc in Model.Documents)
                {
                    var badgeClass = doc.Statut switch
                    {
                        ColisExpress.Domain.Enums.StatutKyc.Valide => "success",
                        ColisExpress.Domain.Enums.StatutKyc.Rejete => "danger",
                        _ => "warning"
                    };
                    var badgeText = doc.Statut switch
                    {
                        ColisExpress.Domain.Enums.StatutKyc.Valide => "Validé",
                        ColisExpress.Domain.Enums.StatutKyc.Rejete => "Rejeté",
                        _ => "En attente"
                    };

                    <div style="border:1px solid var(--admin-border);border-radius:10px;overflow:hidden;">
                        <a href="/api/kyc/document/@doc.Id" target="_blank" style="display:block;background:var(--admin-bg);padding:12px;text-align:center;min-height:140px;display:flex;align-items:center;justify-content:center;">
                            <img src="/api/kyc/document/@doc.Id" alt="@doc.TypeDocument"
                                 style="max-height:200px;max-width:100%;border-radius:6px;"
                                 onerror="this.style.display='none';this.parentElement.innerHTML='<div style=\'color:var(--admin-text-muted);text-align:center;\'><div style=\'font-size:32px;\'>📄</div><div style=\'font-size:12px;margin-top:4px;\'>Cliquer pour ouvrir</div></div>';" />
                        </a>

                        <div style="padding:14px;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:10px;">
                            <div>
                                <div style="font-weight:700;color:var(--admin-text);font-size:14px;">@doc.TypeDocument</div>
                                <div style="font-size:11px;color:var(--admin-text-muted);margin-top:2px;">
                                    @doc.NomFichier — @doc.DateSoumission.ToLocalTime().ToString("dd MMM yyyy HH:mm")
                                </div>
                            </div>

                            <div style="display:flex;gap:8px;align-items:center;">
                                <span class="admin-badge @badgeClass">@badgeText</span>

                                @if (doc.Statut == ColisExpress.Domain.Enums.StatutKyc.EnAttente)
                                {
                                    <form method="post" style="margin:0;">
                                        <input type="hidden" name="documentId" value="@doc.Id" />
                                        <input type="hidden" name="voirKyc" value="@Model.VoirKyc" />
                                        <button type="submit" asp-page-handler="ApproveDoc" class="admin-btn sm success">✓ Valider</button>
                                    </form>
                                    <form method="post" style="margin:0;">
                                        <input type="hidden" name="documentId" value="@doc.Id" />
                                        <input type="hidden" name="voirKyc" value="@Model.VoirKyc" />
                                        <button type="submit" asp-page-handler="RejectDoc" class="admin-btn sm danger">✗ Rejeter</button>
                                    </form>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
}
