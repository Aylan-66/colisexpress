@page "/admin/paiements"
@model ColisExpress.Web.Pages.Admin.PaiementsModel
@{
    ViewData["Title"] = "Paiements";
}

<h1>Paiements</h1>
<p class="subtitle">@Model.TotalCount paiements enregistrés</p>

<form method="get" class="admin-card" style="padding:18px 22px;margin-bottom:24px;display:flex;align-items:center;gap:12px;">
    <label style="font-size:13px;color:var(--admin-text-muted);white-space:nowrap;">Filtrer par mode :</label>
    <select name="ModeFilter" class="admin-field-input" onchange="this.form.submit();" style="max-width:260px;">
        <option value="">Tous les modes</option>
        @foreach (var m in Enum.GetValues<ColisExpress.Domain.Enums.ModeReglement>())
        {
            <option value="@m" selected="@(Model.ModeFilter == m.ToString() ? "selected" : null)">@m</option>
        }
    </select>
    <a class="admin-btn sm outline" asp-page="/Admin/Paiements" asp-page-handler="ExportCsv" asp-route-modeFilter="@Model.ModeFilter" style="white-space:nowrap;margin-left:auto;">Exporter CSV</a>
</form>

<div class="admin-card">
    <table class="admin-table">
        <thead>
            <tr>
                <th>Code colis</th>
                <th>Client</th>
                <th>Mode</th>
                <th>Montant</th>
                <th>Statut</th>
                <th>Date</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var p in Model.Paiements)
            {
                <tr>
                    <td><span class="admin-code">@p.CodeColis</span></td>
                    <td>@p.Client</td>
                    <td>
                        @switch (p.Mode)
                        {
                            case ColisExpress.Domain.Enums.ModeReglement.Carte:
                                <span>Carte</span>
                                break;
                            case ColisExpress.Domain.Enums.ModeReglement.Especes:
                                <span>Espèces</span>
                                break;
                            default:
                                <span>Chèque</span>
                                break;
                        }
                    </td>
                    <td style="font-weight:700;color:var(--admin-text);">@p.Montant.ToString("0.00") €</td>
                    <td>
                        @switch (p.Statut)
                        {
                            case ColisExpress.Domain.Enums.StatutReglement.Paye:
                                <span class="admin-badge success">Payé</span>
                                break;
                            case ColisExpress.Domain.Enums.StatutReglement.Rembourse:
                                <span class="admin-badge warning">Remboursé</span>
                                break;
                            default:
                                <span class="admin-badge neutral">En attente</span>
                                break;
                        }
                    </td>
                    <td>@p.DateCreation.ToLocalTime().ToString("dd MMM HH:mm")</td>
                </tr>
            }
        </tbody>
    </table>
</div>

@if (Model.TotalPages > 1)
{
    <div style="display:flex;align-items:center;justify-content:center;gap:12px;margin-top:20px;">
        @if (Model.Page > 1)
        {
            <a class="admin-btn sm outline" asp-page="/Admin/Paiements" asp-route-page="@(Model.Page - 1)" asp-route-modeFilter="@Model.ModeFilter">Précédent</a>
        }
        <span style="color:var(--admin-text);font-size:14px;">Page @Model.Page sur @Model.TotalPages</span>
        @if (Model.Page < Model.TotalPages)
        {
            <a class="admin-btn sm outline" asp-page="/Admin/Paiements" asp-route-page="@(Model.Page + 1)" asp-route-modeFilter="@Model.ModeFilter">Suivant</a>
        }
    </div>
}
