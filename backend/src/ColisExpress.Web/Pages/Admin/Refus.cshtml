@page "/admin/refus"
@model ColisExpress.Web.Pages.Admin.RefusModel
@{
    ViewData["Title"] = "Refus de colis";
}

<h1>Refus de colis</h1>
<p class="subtitle">Inspection des refus prononcés par les transporteurs et points relais — traitement des remboursements</p>

@if (!string.IsNullOrEmpty(Model.Success))
{
    <div class="admin-card" style="padding:14px 18px;margin-bottom:16px;border-left:4px solid #16a34a;color:#166534;">@Model.Success</div>
}
@if (!string.IsNullOrEmpty(Model.Error))
{
    <div class="admin-card" style="padding:14px 18px;margin-bottom:16px;border-left:4px solid #dc2626;color:#991b1b;">@Model.Error</div>
}

<div class="admin-card" style="padding:18px 22px;margin-bottom:24px;display:flex;gap:32px;align-items:center;">
    <div>
        <div style="font-size:12px;color:var(--admin-text-muted);text-transform:uppercase;letter-spacing:.5px;">Refus à inspecter</div>
        <div style="font-size:28px;font-weight:800;color:#dc2626;">@Model.ANontInspecter.Count</div>
    </div>
    <div>
        <div style="font-size:12px;color:var(--admin-text-muted);text-transform:uppercase;letter-spacing:.5px;">Refus inspectés</div>
        <div style="font-size:28px;font-weight:800;color:#16a34a;">@Model.Inspectes.Count</div>
    </div>
</div>

<h2 style="margin:8px 0 12px;color:#dc2626;">À inspecter (@Model.ANontInspecter.Count)</h2>

@if (!Model.ANontInspecter.Any())
{
    <div class="admin-card" style="padding:24px;text-align:center;color:var(--admin-text-muted);">
        Aucun refus en attente d'inspection.
    </div>
}
else
{
    @foreach (var r in Model.ANontInspecter)
    {
        @await RenderRefusCardAsync(r, true)
    }
}

@if (Model.Inspectes.Any())
{
    <h2 style="margin:32px 0 12px;color:#16a34a;">Refus inspectés (@Model.Inspectes.Count)</h2>
    @foreach (var r in Model.Inspectes)
    {
        @await RenderRefusCardAsync(r, false)
    }
}

@functions {
    private async Task<Microsoft.AspNetCore.Html.IHtmlContent> RenderRefusCardAsync(ColisExpress.Web.Pages.Admin.RefusModel.RefusItem r, bool aInspecter)
    {
        var sb = new System.Text.StringBuilder();
        var bgColor = aInspecter ? "#fef2f2" : "#f0fdf4";
        var borderColor = aInspecter ? "#dc2626" : "#16a34a";
        sb.Append($"<div class=\"admin-card\" style=\"padding:20px;margin-bottom:16px;border-left:4px solid {borderColor};background:{bgColor};\">");

        // Header
        sb.Append("<div style=\"display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:14px;\">");
        sb.Append($"<div><span class=\"admin-code\" style=\"font-size:15px;\">{r.CodeColis}</span> <span style=\"margin-left:12px;font-size:13px;color:var(--admin-text-muted);\">{r.Trajet}</span><br><span style=\"font-size:12px;color:var(--admin-text-muted);\">Segment réservé : <strong>{r.Segment}</strong></span></div>");
        sb.Append($"<div style=\"text-align:right;font-size:12px;color:var(--admin-text-muted);\">Refusé le {r.DateRefus:dd/MM/yyyy HH:mm}<br><strong>{r.RefuseParRole}</strong>{(r.RefuseParNom is null ? "" : " — " + r.RefuseParNom)}</div>");
        sb.Append("</div>");

        // Motif
        sb.Append($"<div style=\"background:white;padding:12px 14px;border-radius:8px;margin-bottom:14px;border:1px solid #e5e7eb;\"><div style=\"font-size:11px;color:var(--admin-text-muted);text-transform:uppercase;letter-spacing:.5px;font-weight:700;\">Motif du refus</div><div style=\"margin-top:4px;font-size:14px;\">{System.Net.WebUtility.HtmlEncode(r.MotifRefus)}</div></div>");

        // Info client + paiement
        sb.Append("<div style=\"display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-bottom:14px;\">");
        sb.Append("<div style=\"background:white;padding:12px 14px;border-radius:8px;border:1px solid #e5e7eb;\">");
        sb.Append($"<div style=\"font-size:11px;color:var(--admin-text-muted);text-transform:uppercase;letter-spacing:.5px;font-weight:700;\">Client</div><div style=\"margin-top:4px;font-weight:700;\">{r.Client}</div><div style=\"font-size:12px;color:var(--admin-text-muted);\">{r.ClientEmail}</div>");
        sb.Append("</div>");
        sb.Append("<div style=\"background:white;padding:12px 14px;border-radius:8px;border:1px solid #e5e7eb;\">");
        sb.Append($"<div style=\"font-size:11px;color:var(--admin-text-muted);text-transform:uppercase;letter-spacing:.5px;font-weight:700;\">Paiement à rembourser</div><div style=\"margin-top:4px;font-weight:700;font-size:18px;color:#1B4965;\">{r.Montant:0.00} €</div><div style=\"font-size:12px;color:var(--admin-text-muted);\">Mode : <strong>{r.ModePaiement}</strong> — Statut : {r.StatutPaiement}</div>");

        if (r.ModePaiement == "Carte" && r.StripeSessionId is not null)
        {
            sb.Append($"<div style=\"margin-top:6px;font-family:monospace;font-size:11px;color:#6b7280;background:#f3f4f6;padding:4px 6px;border-radius:4px;\">Stripe : {r.StripeSessionId}</div>");
            sb.Append($"<a href=\"https://dashboard.stripe.com/test/payments?query={r.StripeSessionId}\" target=\"_blank\" style=\"font-size:12px;color:#1B4965;text-decoration:underline;display:inline-block;margin-top:4px;\">Ouvrir dans Stripe →</a>");
        }
        else if (r.ModePaiement == "Especes" && r.RelaisEncaisseurNom is not null)
        {
            sb.Append($"<div style=\"margin-top:6px;font-size:12px;color:#6b7280;\">Encaissé par : <strong>{r.RelaisEncaisseurNom}</strong></div>");
            sb.Append("<div style=\"margin-top:4px;font-size:12px;color:#dc2626;\">⚠ Remboursement à effectuer en main propre au client</div>");
        }
        sb.Append("</div></div>");

        // Actions
        if (aInspecter)
        {
            sb.Append("<div style=\"display:flex;gap:10px;\">");
            sb.Append($"<form method=\"post\" asp-page-handler=\"MarquerInspecte\" asp-route-colisId=\"{r.ColisId}\" style=\"margin:0;\"><button type=\"submit\" class=\"admin-btn sm\" style=\"background:#1B4965;\">Marquer inspecté</button></form>");
            if (!r.RemboursementEffectue)
            {
                sb.Append($"<form method=\"post\" asp-page-handler=\"MarquerRembourse\" asp-route-commandeId=\"{r.CommandeId}\" style=\"margin:0;\" onsubmit=\"return confirm('Confirmer le remboursement effectué pour cette commande ?');\"><button type=\"submit\" class=\"admin-btn sm outline\">Marquer remboursé</button></form>");
            }
            else
            {
                sb.Append("<span style=\"color:#16a34a;font-weight:600;font-size:13px;align-self:center;\">✓ Remboursé</span>");
            }
            sb.Append("</div>");
        }
        else
        {
            sb.Append($"<div style=\"font-size:12px;color:#16a34a;\">Inspecté le {r.DateInspection?.ToString("dd/MM/yyyy HH:mm") ?? "—"}{(r.RemboursementEffectue ? " — Remboursé ✓" : "")}</div>");
            if (!r.RemboursementEffectue)
            {
                sb.Append($"<form method=\"post\" asp-page-handler=\"MarquerRembourse\" asp-route-commandeId=\"{r.CommandeId}\" style=\"margin:8px 0 0;\" onsubmit=\"return confirm('Confirmer le remboursement effectué pour cette commande ?');\"><button type=\"submit\" class=\"admin-btn sm outline\">Marquer remboursé</button></form>");
            }
        }

        sb.Append("</div>");
        return new Microsoft.AspNetCore.Html.HtmlString(sb.ToString());
    }
}
