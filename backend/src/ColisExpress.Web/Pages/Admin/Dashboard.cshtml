@page "/admin"
@model ColisExpress.Web.Pages.Admin.DashboardModel
@using System.Text.Json
@{
    ViewData["Title"] = "Dashboard";
}

<h1>Dashboard</h1>
<p class="subtitle">Vue d'ensemble de l'activité Colis Express</p>

<div class="admin-kpi-grid">
    <div class="admin-kpi">
        <div class="admin-kpi-label">Colis ce mois</div>
        <div class="admin-kpi-value">@Model.Dashboard.ColisCeMois</div>
        <div class="admin-kpi-hint">Colis créés depuis le 1er</div>
    </div>
    <div class="admin-kpi">
        <div class="admin-kpi-label">Colis livrés</div>
        <div class="admin-kpi-value">@Model.Dashboard.ColisLivres</div>
        <div class="admin-kpi-hint">Statut "Livraison clôturée"</div>
    </div>
    <div class="admin-kpi">
        <div class="admin-kpi-label">Transporteurs actifs</div>
        <div class="admin-kpi-value">@Model.Dashboard.TransporteursActifs</div>
        <div class="admin-kpi-hint">KYC validé</div>
    </div>
    <div class="admin-kpi">
        <div class="admin-kpi-label">Incidents</div>
        <div class="admin-kpi-value">@Model.Dashboard.Incidents</div>
        <div class="admin-kpi-hint">Colis en incident / perdus</div>
    </div>
</div>

<div class="admin-grid-2">
    <div class="admin-card">
        <div class="admin-card-header">
            <h3 class="admin-card-title">Colis par mois</h3>
        </div>
        <div class="admin-card-body" style="padding:16px;">
            <canvas id="chartColisParMois" height="220"></canvas>
        </div>
    </div>
    <div class="admin-card">
        <div class="admin-card-header">
            <h3 class="admin-card-title">Chiffre d'affaires mensuel</h3>
        </div>
        <div class="admin-card-body" style="padding:16px;">
            <canvas id="chartCaParMois" height="220"></canvas>
        </div>
    </div>
</div>

<div class="admin-grid-2">
    <div class="admin-card">
        <div class="admin-card-header">
            <h3 class="admin-card-title">Commandes récentes</h3>
            <a class="admin-btn sm outline" asp-page="/Admin/Commandes">Tout voir →</a>
        </div>
        @if (!Model.Dashboard.CommandesRecentes.Any())
        {
            <div class="admin-card-body" style="color:var(--admin-text-muted);font-size:13px;">Aucune commande pour l'instant.</div>
        }
        else
        {
            <table class="admin-table">
                <thead>
                    <tr>
                        <th>Code</th>
                        <th>Client</th>
                        <th>Trajet</th>
                        <th>Statut</th>
                        <th>Montant</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var c in Model.Dashboard.CommandesRecentes)
                    {
                        <tr>
                            <td><span class="admin-code">@c.CodeColis</span></td>
                            <td>@c.Client</td>
                            <td>@c.Trajet</td>
                            <td><span class="admin-badge primary">@c.Statut</span></td>
                            <td style="font-weight:700;color:var(--admin-text);">@c.Total.ToString("0.00") €</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>

    <div class="admin-card">
        <div class="admin-card-header">
            <h3 class="admin-card-title">KYC en attente (@Model.Dashboard.TransporteursEnAttenteKyc)</h3>
            <a class="admin-btn sm outline" asp-page="/Admin/Transporteurs">Tout voir →</a>
        </div>
        @if (!Model.Dashboard.TransporteursAValider.Any())
        {
            <div class="admin-card-body" style="color:var(--admin-text-muted);font-size:13px;">Aucun KYC en attente.</div>
        }
        else
        {
            <div class="admin-card-body" style="padding:10px 0;">
                @foreach (var t in Model.Dashboard.TransporteursAValider)
                {
                    <div style="padding:12px 22px;border-bottom:1px solid var(--admin-border);">
                        <div style="font-weight:700;color:var(--admin-text);font-size:14px;">@t.Nom</div>
                        <div style="font-size:11px;color:var(--admin-text-muted);margin-top:2px;">@t.Email • @t.TypeVehicule</div>
                    </div>
                }
            </div>
        }
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4"></script>
    <script>
        (function() {
            var colisLabels = @Html.Raw(JsonSerializer.Serialize(Model.Dashboard.ColisParMois.Select(x => x.Label)));
            var colisValues = @Html.Raw(JsonSerializer.Serialize(Model.Dashboard.ColisParMois.Select(x => (double)x.Value)));
            var caLabels = @Html.Raw(JsonSerializer.Serialize(Model.Dashboard.CaParMois.Select(x => x.Label)));
            var caValues = @Html.Raw(JsonSerializer.Serialize(Model.Dashboard.CaParMois.Select(x => (double)x.Value)));

            var chartColors = {
                primary: '#6C5CE7',
                primaryLight: 'rgba(108, 92, 231, 0.15)',
                accent: '#00D2D3',
                accentLight: 'rgba(0, 210, 211, 0.15)',
                text: '#E2E8F0',
                grid: 'rgba(255,255,255,0.06)'
            };

            Chart.defaults.color = chartColors.text;
            Chart.defaults.font.family = "'Plus Jakarta Sans', sans-serif";

            new Chart(document.getElementById('chartColisParMois'), {
                type: 'bar',
                data: {
                    labels: colisLabels,
                    datasets: [{
                        label: 'Colis',
                        data: colisValues,
                        backgroundColor: chartColors.primary,
                        borderRadius: 6,
                        borderSkipped: false
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: { legend: { display: false } },
                    scales: {
                        y: { beginAtZero: true, grid: { color: chartColors.grid }, ticks: { precision: 0 } },
                        x: { grid: { display: false } }
                    }
                }
            });

            new Chart(document.getElementById('chartCaParMois'), {
                type: 'line',
                data: {
                    labels: caLabels,
                    datasets: [{
                        label: 'CA (€)',
                        data: caValues,
                        borderColor: chartColors.accent,
                        backgroundColor: chartColors.accentLight,
                        fill: true,
                        tension: 0.35,
                        pointBackgroundColor: chartColors.accent,
                        pointRadius: 5,
                        pointHoverRadius: 7
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: { legend: { display: false } },
                    scales: {
                        y: { beginAtZero: true, grid: { color: chartColors.grid }, ticks: { callback: function(v) { return v + ' €'; } } },
                        x: { grid: { display: false } }
                    }
                }
            });
        })();
    </script>
}
