@page
@model ErrorModel
@{
    ViewData["Title"] = "Erreur";
}

<section class="web-page narrow">
    <div class="web-card text-center" style="padding:48px 24px;">
        <div style="font-size:56px;margin-bottom:16px;">⚠️</div>
        <h1 style="font-size:26px;margin-bottom:8px;">Oups, une erreur est survenue</h1>
        <p class="text-muted mb-4">
            Impossible de traiter votre demande pour le moment. Veuillez réessayer dans quelques instants.
        </p>

        @if (Model.ShowRequestId)
        {
            <div style="background:var(--gray-50);border:1px solid var(--gray-200);border-radius:8px;padding:10px 14px;display:inline-block;margin-bottom:16px;">
                <span class="text-muted" style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.5px;">Code d'erreur</span><br>
                <code style="font-family:'JetBrains Mono', monospace;font-size:12px;color:var(--primary);">@Model.RequestId</code>
            </div>
        }

        <div class="flex gap-2 items-center" style="justify-content:center;">
            <a class="web-btn outline" asp-page="/Index">← Retour à l'accueil</a>
            <a class="web-btn" asp-page="/Client/Recherche">Rechercher un transporteur</a>
        </div>

        <p class="text-muted" style="font-size:11px;margin-top:24px;">
            Si le problème persiste, contactez le support.
        </p>
    </div>
</section>
